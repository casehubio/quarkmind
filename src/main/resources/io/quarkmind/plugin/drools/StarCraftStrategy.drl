package io.quarkmind.plugin.drools;
unit StrategyRuleUnit;

import io.quarkmind.domain.BuildingType;
import io.quarkmind.domain.UnitType;

// ---------------------------------------------------------------------------
// Build Order Rules (salience 100..70)
//
// Rules write string decisions to buildDecisions (a JDK List<String> global).
// Budget enforcement and IntentQueue dispatch happen in DroolsStrategyTask
// AFTER fire() completes — application-typed objects never enter the DRL layer.
//
// Syntax notes:
//  - No-constraint pattern: /store  (NOT /store[])
//  - Record accessors: this.method() to avoid DRL keyword clashes (e.g. "type")
// ---------------------------------------------------------------------------

rule "Build Gateway"
    salience 100
when
    /builders
    not /buildings[ this.type() == BuildingType.GATEWAY ]
    /buildings[ this.type() == BuildingType.PYLON, this.isComplete() == true ]
then
    buildDecisions.add("GATEWAY");
end

rule "Build Assimilator"
    salience 90
when
    /builders
    /buildings[ this.type() == BuildingType.GATEWAY, this.isComplete() == true ]
    /geysers
then
    buildDecisions.add("ASSIMILATOR");
end

rule "Build CyberneticsCore"
    salience 80
when
    /builders
    /buildings[ this.type() == BuildingType.GATEWAY, this.isComplete() == true ]
    not /buildings[ this.type() == BuildingType.CYBERNETICS_CORE ]
then
    buildDecisions.add("CYBERNETICS_CORE");
end

// Fires once per complete Gateway — DroolsStrategyTask uses the tag to queue TrainIntent.
rule "Train Stalker"
    salience 70
when
    $gw: /buildings[ this.type() == BuildingType.GATEWAY, this.isComplete() == true ]
    /buildings[ this.type() == BuildingType.CYBERNETICS_CORE, this.isComplete() == true ]
then
    buildDecisions.add("STALKER:" + $gw.tag());
end

// ---------------------------------------------------------------------------
// Strategy Assessment Rules (salience 210..150)
// Driven by scouting-derived intel stored in postureStore and timingStore.
// eval() + accumulate() does not compile in the current Drools version, so
// posture and timing are fed as DataStore facts for pattern-matching.
// Two DEFEND rules used instead of the or-keyword: or fires once per matching
// alternative, adding "DEFEND" twice when both conditions hold. findFirst()
// handles that, but two rules with a not-timing guard on the second are cleaner.
// ATTACK fires when no threat signal — UNKNOWN posture is treated as
// equivalent to the old "not /enemies" signal (no current enemy contact).
// See protocol: docs/protocols/strategy-attack-under-unknown-posture.md
// Default is "MACRO" (empty strategyDecisions list).
// ---------------------------------------------------------------------------

rule "Strategy: Defend — Timing Attack"
    salience 210
when
    /timingStore[ this == true ]
then
    strategyDecisions.add("DEFEND");
end

rule "Strategy: Defend — All-In Posture"
    salience 200
when
    not /timingStore[ this == true ]
    /postureStore[ this.equals("ALL_IN") ]
then
    strategyDecisions.add("DEFEND");
end

rule "Strategy: Attack"
    salience 150
when
    not /timingStore[ this == true ]
    not /postureStore[ this.equals("ALL_IN") ]
    accumulate(
        /army[ this.type() == UnitType.STALKER ];
        $count : count();
        $count >= 4
    )
then
    strategyDecisions.add("ATTACK");
end
